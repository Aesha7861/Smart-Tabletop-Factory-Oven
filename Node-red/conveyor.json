    {
        "id": "35e79c160b624233",
        "type": "function",
        "z": "13e81bc0e31599b1",
        "name": "notify_turntable_reset",
        "func": "const prev = flow.get(\"prev_I3\") || 0;\nconst curr = msg.payload.I3_end_sensor;\n\nflow.set(\"prev_I3\", curr);\n\n// Detect falling edge of I3 (after delayed stop)\nif (prev === 1 && curr === 0) {\n    return {\n        topic: \"stf/turntable/cmd/reset\",\n        payload: \"1\"\n    };\n}\n\nreturn null;\n",
