        "name": "Cookie present",
        "func": "// Only say YES if the piece is there AND the motor is actually running\nif (msg.payload.motor === true && msg.payload.piece_present === true) {\n    msg.payload = \"YES\";\n} else {\n    // Default to NO if motor is off, even if sensor is triggered\n    msg.payload = \"NO\";\n}\nreturn msg;",
