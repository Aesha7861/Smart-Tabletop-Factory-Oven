        "name": "status_led",
        "func": "const s = (msg.payload.state || \"\").toUpperCase();\n\nif (s === \"BAKING\") msg.payload = \"🟢 RUNNING\";\nelse if (s === \"LOADING\" || s === \"UNLOADING\") msg.payload = \"🟠 BUSY\";\nelse if (s === \"FAULT\") msg.payload = \"🔴 FAULT\";\nelse msg.payload = \"⚪ IDLE\";\n\nreturn msg;\n",
